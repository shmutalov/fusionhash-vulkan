const uint aes_rcon[8] = uint[8](0x8Du, 0x01u, 0x02u, 0x04u, 0x08u, 0x10u, 0x20u, 0x40u);

uint SubWord(uint inw) {
    return (aes_sbox[BYTE(inw, 3u)] << 24) | (aes_sbox[BYTE(inw, 2u)] << 16) |
           (aes_sbox[BYTE(inw, 1u)] << 8)  |  aes_sbox[BYTE(inw, 0u)];
}

void AESExpandKey256(inout uint keybuf[40]) {
    uint i = 1u;
    for (uint c = 8u; c < 40u; ++c) {
        uint t = ((c & 7u) == 0u || (c & 7u) == 4u) ? SubWord(keybuf[c - 1u]) : keybuf[c - 1u];
        if ((c & 7u) == 0u) {
            t = rotl32(t, 24u) ^ aes_rcon[i];
            ++i;
        }
        keybuf[c] = keybuf[c - 8u] ^ t;
    }
}

